# Normalize all text files to LF in the repository.
# Prevents CRLF/LF churn that makes git see whole files as changed.
* text=auto eol=lf

# Explicit text files
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.csv   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.toml  text eol=lf
*.sh    text eol=lf
*.env   text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# Binary files (never touch line endings)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.xlsx    binary
*.xls     binary
*.pkl     binary
*.pickle  binary
*.parquet binary
*.joblib  binary
*.h5      binary
*.zip     binary
