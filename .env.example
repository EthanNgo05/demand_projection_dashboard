# Copy to .env and fill in. .env is gitignored; never commit real keys.

# LLM provider for the Phase 4 reasoning nodes:
#   anthropic  -> Claude API (requires ANTHROPIC_API_KEY)
#   local      -> any OpenAI-compatible server (LiteLLM / LM Studio / vLLM)
LLM_PROVIDER=local

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Optional override (defaults to claude-sonnet-5)
#ANTHROPIC_MODEL=claude-sonnet-5

# Used when LLM_PROVIDER=local (defaults shown)
#LOCAL_LLM_BASE_URL=http://james-workstation:4000/v1
#LOCAL_LLM_MODEL=gemma4-31b
#LOCAL_LLM_API_KEY=not-needed

# SQL Server connection for extract_demand_details.py (pulls from the DW).
# SQL_SERVER and SQL_DATABASE are REQUIRED (no hardcoded defaults in source).
# Leave SQL_USER blank to use Windows (trusted) auth. If SQL_USER is set,
# SQL_PASSWORD must be non-empty (a blank password is rejected).
SQL_SERVER=
SQL_DATABASE=
SQL_USER=
SQL_PASSWORD=
# Optional overrides (secure defaults shown):
#SQL_DRIVER=ODBC Driver 18 for SQL Server
#SQL_ENCRYPT=yes           # encrypt in transit; set 'no' only if you must
#SQL_TRUST_CERT=no         # 'yes' disables cert validation (warned, insecure)
#SQL_SERVER_CERT=          # path to the DW's cert (.cer/.pem) to pin & validate
                           #   securely without setting SQL_TRUST_CERT=yes
#SQL_LOGIN_TIMEOUT=30      # seconds to establish the connection
#SQL_QUERY_TIMEOUT=900     # seconds for the batch; 0 = unlimited
#DEMAND_RAW_DIR=           # where the dated output .xlsx is written; defaults to
                           #   raw_inputs/demand_projections (the folder the
                           #   dashboard discovers snapshots in), so a plain run
                           #   feeds the dashboard with no copy step.
